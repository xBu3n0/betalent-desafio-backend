# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Default Database
DEFAULT_DB_CONNECTION=mysql

# MySQL Database
MYSQL_DATABASE=betalent-challenge
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=user_password

# MySQL for integration tests
MYSQL_TEST_DATABASE=betalent-challenge-test
MYSQL_TEST_HOST=mysql_test
MYSQL_TEST_PORT=3306
MYSQL_TEST_USER=user
MYSQL_TEST_PASSWORD=user_password

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000